# Copy this file to .env.local and fill in your actual values
# (.env.local is gitignored — your secrets stay on your computer)

# Your Google Sheet "Lakespring_Website_Public_Data" published as CSV
# How to get this URL:
#   1. Open the sheet
#   2. File > Share > Publish to web
#   3. Choose the "Holdings" tab, format: Comma-separated values (.csv)
#   4. Click Publish, copy the URL
NEXT_PUBLIC_SHEET_HOLDINGS_URL=https://docs.google.com/spreadsheets/d/PASTE_ID/export?format=csv&gid=0

# Same process for the Performance tab
NEXT_PUBLIC_SHEET_PERFORMANCE_URL=https://docs.google.com/spreadsheets/d/PASTE_ID/export?format=csv&gid=1

# Your Beehiiv embed form URL
NEXT_PUBLIC_BEEHIIV_EMBED_URL=https://embeds.beehiiv.com/0a30b2d5-820a-460f-b5da-e166b7ae408f
